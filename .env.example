# ── Provider ──────────────────────────────────────────
# 可选: codex（默认）, gemini-cli。未来将支持 claude-code, cursor-cli
PROVIDER=codex

# ── Codex CLI ────────────────────────────────────────
CODEX_BIN=codex
CODEX_MODEL=
CODEX_SANDBOX=read-only
CODEX_SYSTEM_PROMPT=
# Codex 的工作目录，留空则使用当前目录
CODEX_WORKDIR=

# ── Gemini CLI ───────────────────────────────────────
GEMINI_CLI_BIN=gemini
GEMINI_CLI_MODEL=
GEMINI_CLI_APPROVAL_MODE=yolo

# ── Web ──────────────────────────────────────────────
WEB_PORT=19981

# ── 日志 ─────────────────────────────────────────────
LOG_LEVEL=info
LOG_INCLUDE_CONTENT=false
LOG_INCLUDE_PROMPT=false
